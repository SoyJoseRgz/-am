{
  "name": "backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "migrate:up": "node-pg-migrate up --migration-file-language ts",
    "migrate:down": "node-pg-migrate down --migration-file-language ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^10.1.0",
    "bcrypt": "^5.1.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^6.0.0",
    "ioredis": "^5.4.0",
    "jose": "^5.9.0",
    "node-pg-migrate": "^7.0.0",
    "pg": "^8.13.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.35.3",
    "socket.io": "^4.8.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
